{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocketgpt/contracts/iq-scorecard.schema.json",
  "title": "IQScorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "scorecard_id",
    "session_id",
    "overall_score",
    "dimensions",
    "generated_at"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["1.0"] },
    "scorecard_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "generated_at": { "type": "string", "format": "date-time" },
    "flags": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "score"],
        "properties": {
          "key": {
            "type": "string",
            "enum": ["correctness", "safety", "latency", "cost", "governance", "robustness"]
          },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "rationale": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
          "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
          "bytes": { "type": "number", "minimum": 0 },
          "checksum_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
