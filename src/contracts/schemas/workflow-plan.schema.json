{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocketgpt/contracts/workflow-plan.schema.json",
  "title": "WorkflowPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "plan_id",
    "session_id",
    "objective",
    "steps",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["1.0"] },
    "plan_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "objective": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "created_at": { "type": "string", "format": "date-time" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "title": { "type": "string", "minLength": 1, "maxLength": 512 },
          "owner": { "type": "string", "minLength": 1, "maxLength": 128 },
          "depends_on": {
            "type": "array",
            "maxItems": 16,
            "items": { "type": "string", "minLength": 1, "maxLength": 128 }
          },
          "estimated_ms": { "type": "number", "minimum": 0, "maximum": 86400000 },
          "max_db_queries": { "type": "number", "minimum": 0, "maximum": 100 },
          "artifact_refs": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": {
                "id": { "type": "string", "minLength": 1, "maxLength": 256 },
                "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
                "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
                "bytes": { "type": "number", "minimum": 0 },
                "checksum_sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              }
            }
          }
        }
      }
    }
  }
}
