{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocketgpt/contracts/analysis-report.schema.json",
  "title": "AnalysisReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "report_id",
    "session_id",
    "status",
    "workflow_plan_ref",
    "scorecard_ref",
    "evidence_pack_ref",
    "generated_at"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["1.0"] },
    "report_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "status": { "type": "string", "enum": ["ok", "needs_review", "blocked"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "workflow_plan_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
        "bytes": { "type": "number", "minimum": 0 },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "scorecard_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
        "bytes": { "type": "number", "minimum": 0 },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "evidence_pack_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
        "bytes": { "type": "number", "minimum": 0 },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 128 },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "message": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "evidence_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1, "maxLength": 256 },
              "uri": { "type": "string", "minLength": 1, "maxLength": 2048 },
              "media_type": { "type": "string", "minLength": 1, "maxLength": 128 },
              "bytes": { "type": "number", "minimum": 0 },
              "checksum_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    }
  }
}
