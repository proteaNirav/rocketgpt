  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".tmp/task-tests",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": false
