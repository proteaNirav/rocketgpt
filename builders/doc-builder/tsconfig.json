{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../..",
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "../../shared/**/*.ts",
    "../../runtime/sandbox-runner/src/**/*.ts",
    "../../builders/builder-sdk/src/**/*.ts"
  ]
}
